{
  "name": "help-desk",
  "version": "0.0.0",
  "scripts": {
    "faq:build": "node tools/generate-faq-json.mjs",
    "start": "npm run faq:build && ng serve",
    "build": "npm run faq:build && ng build",
    "watch": "npm run faq:build && ng build --watch --configuration development",
    "test": "npm run faq:build && ng test",
    "build-for-production": "npm run faq:build && ng build --configuration=production",
    "build:public": "node tools/build-public-help.mjs",
    "serve:ssr:HelpDesk": "node dist/HelpDesk/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "express": "^5.1.0",
    "marked": "^17.0.3",
    "ngx-markdown": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
